{
  "name": "pencil-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "bash ./scripts/dev-with-tunnel.sh",
    "dev:figma": "sh -c 'ENABLE_FIGMA_WATCH=1 bash ./scripts/dev-with-tunnel.sh'",
    "dev:local": "sh -c 'NEXT_DISABLE_WEBPACK_CACHE=${NEXT_DISABLE_WEBPACK_CACHE:-1} NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-dev} next dev -p ${APP_PORT:-3001}'",
    "session:menu": "bash ./scripts/git-session.sh menu",
    "session:start": "bash ./scripts/git-session.sh start",
    "session:sync": "bash ./scripts/git-session.sh sync",
    "session:finish": "bash ./scripts/git-session.sh finish",
    "session:handoff": "bash ./scripts/git-session.sh handoff",
    "session:merge": "bash ./scripts/git-session.sh merge",
    "session:status": "bash ./scripts/git-session.sh status",
    "tunnel": "node ./scripts/tunnel-localhost-run.mjs",
    "figma:sync": "node ./scripts/figma-sync.mjs",
    "figma:watch": "node ./scripts/figma-watch.mjs",
    "validate:assets": "node ./scripts/validate-static-assets.mjs",
    "vercel:link": "npx --yes vercel link",
    "deploy:preview": "npx --yes vercel deploy",
    "deploy:prod": "npx --yes vercel deploy --prod",
    "build": "npm run -s validate:assets && sh -c 'NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-build} next build'",
    "start": "sh -c 'NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-build} next start -p ${APP_PORT:-3001}'",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "qrcode-terminal": "^0.12.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0"
  }
}
